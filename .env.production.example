# ===========================================
# CVE Threat Radar - Production Environment Template
# ===========================================
# IMPORTANT: Copy this to .env and fill in secure values
# NEVER commit .env with real credentials to version control!
#
# Generate secure values:
#   SECRET_KEY: openssl rand -base64 32
#   POSTGRES_PASSWORD: openssl rand -base64 24
# ===========================================

# Application
ENVIRONMENT=production
DEBUG=false

# Security - REQUIRED: Generate with: openssl rand -base64 32
SECRET_KEY=<generate-secure-key>

# Authentication - Enable in production
AUTH_ENABLED=true
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Specify your production domains
ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Database - PostgreSQL for production
POSTGRES_USER=cve_radar
POSTGRES_PASSWORD=<generate-secure-password>
POSTGRES_DB=cve_threat_radar
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_PASSWORD=<generate-secure-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# NVD API Key (recommended for production)
# Get your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=<your-nvd-api-key>

# ML Model Settings
MODEL_PATH=/app/models
PREDICTION_THRESHOLD=0.5

# Feed Sync Settings
FEED_UPDATE_INTERVAL_HOURS=6
FEED_SCHEDULER_ENABLED=true
FEED_SCHEDULER_MAX_INSTANCES=1

# Metrics - Protect in production
METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=true
