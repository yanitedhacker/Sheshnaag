# ===========================================
# Project Sheshnaag - Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed
# IMPORTANT: Never commit .env files with real credentials!
#
# Generate secure values with:
#   openssl rand -base64 32
#   openssl rand -base64 24

# ===========================================
# REQUIRED - Must be set before running
# ===========================================

# Security - Generate with: openssl rand -base64 32
SECRET_KEY=change-this-to-a-secure-random-string

# Database credentials (required for Docker)
POSTGRES_PASSWORD=change_me_to_strong_random

# Redis password (required for Docker)
REDIS_PASSWORD=change_me_to_strong_random

# ===========================================
# Application Settings
# ===========================================

ENVIRONMENT=development
DEPLOYMENT_PROFILE=local_dev
DEPLOYMENT_NAME=sheshnaag-local
DEBUG=false

# Authentication
AUTH_ENABLED=true
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Allowed origins (comma-separated)
# Set to your deployed frontend origin in production
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=2000

# ===========================================
# Database Configuration
# ===========================================

# SQLite for local development (no Docker)
DATABASE_URL=sqlite:///./sheshnaag.db

# PostgreSQL (Docker/production) - uncomment and configure:
# POSTGRES_USER=sheshnaag
# POSTGRES_DB=sheshnaag
# DATABASE_URL=postgresql://sheshnaag:${POSTGRES_PASSWORD}@db:5432/sheshnaag

# ===========================================
# Redis Configuration
# ===========================================

# Local development (no auth)
# REDIS_URL=redis://localhost:6379/0

# Docker (with auth) - password is automatically included
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ===========================================
# Provenance / Signing
# ===========================================

SIGNING_KEY_DIR=/tmp/sheshnaag_signing_keys
SIGNING_KEY_BACKEND=local-file
# SIGNING_KEY_BACKUP_DIR=./data/signing-key-backups

# ===========================================
# Trusted lab images
# ===========================================

SHESHNAAG_BASELINE_IMAGE=kalilinux/kali-rolling:2026.1
SHESHNAAG_OSQUERY_IMAGE=sheshnaag-kali-osquery:2026.1
SHESHNAAG_TRACEE_IMAGE=sheshnaag-kali-tracee:2026.1
SHESHNAAG_LIMA_IMAGE=sheshnaag-lima-ubuntu:2026.1

# ===========================================
# Release verification
# ===========================================

RELEASE_METADATA_DIR=./data/release_metadata

# ===========================================
# External APIs
# ===========================================

# NVD API Key (optional, increases rate limit)
# Get your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ===========================================
# ML Model Settings
# ===========================================

MODEL_PATH=./models
PREDICTION_THRESHOLD=0.5

# ===========================================
# Scheduler Settings
# ===========================================

FEED_UPDATE_INTERVAL_HOURS=6
FEED_SCHEDULER_ENABLED=true

# ===========================================
# Metrics & Monitoring
# ===========================================

METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=false
