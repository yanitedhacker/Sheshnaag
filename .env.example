# ===========================================
# CVE Threat Radar - Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed
# IMPORTANT: Never commit .env files with real credentials!

# Application
ENVIRONMENT=development
DEBUG=false

# Security - Generate with: openssl rand -base64 32
SECRET_KEY=change-this-to-a-secure-random-string

# Authentication
AUTH_ENABLED=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=2000

# Database (SQLite for local development)
DATABASE_URL=sqlite:///./cve_threat_radar.db

# For PostgreSQL (Docker/production):
# POSTGRES_USER=cve_radar
# POSTGRES_PASSWORD=your_secure_password
# POSTGRES_DB=cve_threat_radar
# DATABASE_URL=postgresql://cve_radar:your_secure_password@db:5432/cve_threat_radar

# Redis (optional, for caching/queues)
REDIS_URL=redis://localhost:6379/0

# NVD API Key (optional, increases rate limit)
# Get your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ML Model Settings
MODEL_PATH=./models
PREDICTION_THRESHOLD=0.5

# Feed Sync Settings
FEED_UPDATE_INTERVAL_HOURS=6
FEED_SCHEDULER_ENABLED=true

# Metrics
METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=false
