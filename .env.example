# ===========================================
# CVE Threat Radar - Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string

# Database (SQLite for local development)
DATABASE_URL=sqlite:///./cve_threat_radar.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/cve_threat_radar

# Redis (optional, for caching/queues)
REDIS_URL=redis://localhost:6379/0

# NVD API Key (optional, increases rate limit)
# Get your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ML Model Settings
MODEL_PATH=./models
PREDICTION_THRESHOLD=0.5

# Feed Sync Settings
FEED_UPDATE_INTERVAL_HOURS=6
